# Copy to .env before running docker compose if you want to override defaults.

# Public ports
CVN_WEB_PORT=5173
CVN_API_PORT=8000
# For reverse-proxy/NAS exposure, prefer publishing only CVN_WEB_PORT and bind
# the raw API port to loopback:
# CVN_API_PORT=127.0.0.1:8000

# Optional local/NAS operator token.
# Generate one with: openssl rand -base64 36
# When set, all API routes except /api/health require the token.
CVN_AUTH_TOKEN=

# Host folders mounted into the backend container.
# Keep DB metadata, downloaded media, and runtime overrides in separate host
# folders. Mount Doctor checks this separation from the dashboard.
# Local defaults:
CVN_METADATA_HOST_DIR=./metadata
CVN_DOWNLOAD_HOST_DIR=./downfolder
CVN_RUNTIME_HOST_DIR=./runtime
# NAS example:
# CVN_METADATA_HOST_DIR=/volume1/channel-vault-nas/metadata
# CVN_DOWNLOAD_HOST_DIR=/volume1/channel-vault-nas/archive
# CVN_RUNTIME_HOST_DIR=/volume1/channel-vault-nas/runtime

# Startup safety
CVN_DB_BACKUP_ON_STARTUP=true
CVN_DB_MIGRATE_ON_STARTUP=true

# Real media transfer remains disabled by default.
CVN_DOWNLOAD_WORKER_ENABLED=false
CVN_DOWNLOAD_WORKER_SCHEDULER_ENABLED=false
CVN_DOWNLOAD_WORKER_SCHEDULER_INTERVAL_SECONDS=300
CVN_DOWNLOAD_WORKER_SCHEDULER_LIMIT=1

# Metadata sync scheduler
CVN_METADATA_SYNC_SCHEDULER_ENABLED=false
CVN_METADATA_SYNC_SCHEDULER_INTERVAL_SECONDS=900
CVN_METADATA_SYNC_SCHEDULER_LIMIT=2

# Binaries inside the backend image
CVN_YTDLP_BINARY=yt-dlp
CVN_FFPROBE_BINARY=ffprobe

# Runtime restart adapter. Execution stays disabled until explicitly enabled.
CVN_RESTART_ADAPTER=docker-compose
CVN_RESTART_SERVICE_NAME=api
CVN_RESTART_ADAPTER_EXECUTE=false
